# --- REQUIRED ---
# Get these from your Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- ADMIN / SERVER SIDE ---
# Get this from Supabase Dashboard -> Project Settings -> API
# (Keep this private - it bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- EMAIL & AUTOMATION (Phase 4) ---
# Get these from resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=updates@yourdomain.com
ADMIN_EMAIL=your-email@example.com

# A random secret for your Vercel Cron jobs
CRON_SECRET=make_up_a_random_string

# --- AI ENGINES (Optional) ---
# For future AI integrations
OPENAI_API_KEY=sk-...
